# React 19 + the shadcn/Radix component kit: several UI deps (e.g.
# react-day-picker@8) still declare React 16–18 as their peer. They work
# fine on React 19 in practice, so accept the peer mismatch globally rather
# than per-command. Keeps `npm install` deterministic for dev and for the
# Tauri build step.
legacy-peer-deps=true
